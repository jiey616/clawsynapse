# ────────────────────────────────────────────
# ClawSynapse + Hermes Docker 环境变量
# 复制为 .env 并填写实际值后 docker compose up -d
#   cp .env.example .env
# ────────────────────────────────────────────

# ── ClawSynapse 身份 (可选，留空由 init 自动生成) ──
CLAWSYNAPSE_NODE_ID=
CLAWSYNAPSE_NODE_KEY=
CLAWSYNAPSE_AGENT_ROLE=pm          # pm | executor | "" (空则无业务 skill)

# ── ClawSynapse API 监听地址 ──
CLAWSYNAPSE_API_LISTEN=0.0.0.0:8080
CLAWSYNAPSE_API_PORT=8080

# ── Hermes LLM Provider (至少填一组) ──
# DeepSeek (推荐，性价比高)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 其他 LLM 提供商 (可选)
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# NOVITA_API_KEY=
# OLLAMA_API_KEY=
