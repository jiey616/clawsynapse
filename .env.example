# ── ClawSynapse Docker Environment Variables ──
# Copy to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── ClawSynapse Identity (used by `clawsynapse init`) ──
# Leave empty for first run — init will generate them.
# For reproducible deploys, pre-generate with `clawsynapse auth keygen`.
CLAWSYNAPSE_NODE_ID=
CLAWSYNAPSE_NODE_KEY=
CLAWSYNAPSE_AGENT_ROLE=pm          # pm | executor | ""

# ── API Listen Address ──
# Inside container: 0.0.0.0:8080 (default)
# On host port mapping: see docker-compose.yml ports section
CLAWSYNAPSE_API_LISTEN=0.0.0.0:8080
CLAWSYNAPSE_API_PORT=8080

# ── Hermes Configuration ──
# Add any API keys or config hermes needs at runtime
HERMES_API_KEY=
# OPENAI_API_KEY=
