# ────────────────────────────────────────────
# ClawSynapse + Hermes Docker 环境变量
# 复制为 .env 并根据实际情况修改
#   cp .env.example .env
# ────────────────────────────────────────────

# ── ClawSynapse 身份 (可选，留空由 init 自动生成) ──
CLAWSYNAPSE_NODE_ID=
CLAWSYNAPSE_NODE_KEY=
CLAWSYNAPSE_AGENT_ROLE=pm          # pm | executor | "" (空则无业务 skill)

# ── ClawSynapse API 监听地址 ──
CLAWSYNAPSE_API_LISTEN=0.0.0.0:8080
CLAWSYNAPSE_API_PORT=8080

# ════════════════════════════════════════════════
# Hermes LLM — 默认使用 TokenFlow (OpenAI 兼容)
# ════════════════════════════════════════════════

# ── TokenFlow (默认，已预填) ──
TOKENFLOW_API_KEY=sk-pjh88cnMJ4EZIiyZpD63NK7gJeji9VCvU23VPRbiSd7uhwou
TOKENFLOW_BASE_URL=http://36.137.106.15:3030/v1

# ── Hermes 模型配置 (已默认指向 TokenFlow) ──
# ⚠️ 必须指定 TokenFlow 提供的模型名，例如 gpt-3.5-turbo / qwen-plus / etc.
HERMES_MODEL=
# HERMES_MODEL=gpt-3.5-turbo
HERMES_PROVIDER=openai
HERMES_BASE_URL=http://36.137.106.15:3030/v1

# ────────────────────────────────────────────
# 切换到其他 provider 时，取消下面注释并修改
# ────────────────────────────────────────────
# DeepSeek:
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# HERMES_MODEL=deepseek-v4-flash
# HERMES_PROVIDER=deepseek
# HERMES_BASE_URL=https://api.deepseek.com

# OpenAI:
# OPENAI_API_KEY=sk-your-openai-key
# HERMES_MODEL=gpt-4o
# HERMES_PROVIDER=openai
# HERMES_BASE_URL=

# OpenRouter (一个 key 访问 100+ 模型):
# OPENROUTER_API_KEY=sk-or-your-key
# HERMES_MODEL=anthropic/claude-sonnet-4
# HERMES_PROVIDER=openrouter
# HERMES_BASE_URL=

# Gemini:
# GOOGLE_API_KEY=your-google-key
# HERMES_MODEL=gemini-2.5-flash
# HERMES_PROVIDER=google
# HERMES_BASE_URL=

# NovitaAI:
# NOVITA_API_KEY=your-novita-key
# NOVITA_BASE_URL=https://api.novita.ai/openai/v1
# HERMES_MODEL=
# HERMES_PROVIDER=novita
# HERMES_BASE_URL=
