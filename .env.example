# ────────────────────────────────────────────
# ClawSynapse + Hermes Docker 环境变量
# 复制为 .env 并填写实际值后 docker compose up -d
#   cp .env.example .env
# ────────────────────────────────────────────

# ── ClawSynapse 身份 (可选，留空由 init 自动生成) ──
CLAWSYNAPSE_NODE_ID=
CLAWSYNAPSE_NODE_KEY=
CLAWSYNAPSE_AGENT_ROLE=pm          # pm | executor | "" (空则无业务 skill)

# ── ClawSynapse API 监听地址 ──
CLAWSYNAPSE_API_LISTEN=0.0.0.0:8080
CLAWSYNAPSE_API_PORT=8080

# ════════════════════════════════════════════════
# Hermes LLM 配置 — 选一个 provider 即可
# 需要同时配置: (A) API Key  (B) 模型信息
# ════════════════════════════════════════════════

# ── (A) API Key — 填你使用的那个 provider 的 key ──
# DeepSeek (默认，性价比高)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key

# OpenRouter (一个 key 访问 100+ 模型)
# OPENROUTER_API_KEY=sk-or-your-key

# Google AI Studio / Gemini
# GOOGLE_API_KEY=your-google-key
# GEMINI_API_KEY=your-gemini-key

# NovitaAI (90+ 模型, 按量付费)
# NOVITA_API_KEY=your-novita-key
# NOVITA_BASE_URL=https://api.novita.ai/openai/v1

# Ollama Cloud
# OLLAMA_API_KEY=your-ollama-key

# ── (B) 模型信息 — 告诉 hermes 用哪个模型 ──
# 留空则使用 hermes 默认值 (deepseek-v4-flash)
# HERMES_MODEL=deepseek-v4-flash
# HERMES_PROVIDER=deepseek
# HERMES_BASE_URL=https://api.deepseek.com

# ── 常见模型配置示例 ──
# DeepSeek:    HERMES_MODEL=deepseek-v4-flash    HERMES_PROVIDER=deepseek    HERMES_BASE_URL=https://api.deepseek.com
# OpenAI:      HERMES_MODEL=gpt-4o               HERMES_PROVIDER=openai      HERMES_BASE_URL=
# Claude:      HERMES_MODEL=claude-sonnet-4-20250514  HERMES_PROVIDER=anthropic  HERMES_BASE_URL=
# Gemini:      HERMES_MODEL=gemini-2.5-flash      HERMES_PROVIDER=google      HERMES_BASE_URL=
# OpenRouter:  HERMES_MODEL=anthropic/claude-sonnet-4  HERMES_PROVIDER=openrouter  HERMES_BASE_URL=
