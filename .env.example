# ────────────────────────────────────────────
# ClawSynapse + Hermes Docker 环境变量
# 复制为 .env 并根据实际情况修改
#   cp .env.example .env
# ────────────────────────────────────────────

# ── Docker 镜像源 (本地构建留空，从 registry 拉取则填写) ──
# 默认使用腾讯云 TCR 已构建好的多架构镜像 (国内速度快):
CLAWSYNAPSE_IMAGE=ccr.ccs.tencentyun.com/jiey616/clawsynapse:v1.0.20
# 国外可用 ghcr.io:
# CLAWSYNAPSE_IMAGE=ghcr.io/jiey616/clawsynapse:v1.0.20

# ── ClawSynapse 身份 (可选，留空由 init 自动生成) ──
CLAWSYNAPSE_NODE_ID=
CLAWSYNAPSE_NODE_KEY=
# AGENT_ROLE: pm | executor | "" (空则无业务 skill)
CLAWSYNAPSE_AGENT_ROLE=executor

# ── ClawSynapse API 监听地址 ──
# 注意：v1.0.19+ 容器内默认端口已改为 18080，须与 docker-compose.yml 的端口映射一致
CLAWSYNAPSE_API_LISTEN=0.0.0.0:18080
CLAWSYNAPSE_API_PORT=18080

# ════════════════════════════════════════════════
# Hermes LLM — 默认使用 TokenFlow (OpenAI 兼容)
# ════════════════════════════════════════════════

# ── TokenFlow API key (自定义 provider 与 OpenAI 兼容模式共用) ──
TOKENFLOW_API_KEY=sk-your-tokenflow-key
TOKENFLOW_BASE_URL=http://36.137.106.15:3030/v1

# ── Hermes 自定义 Provider (推荐) ──
# 当 HERMES_CUSTOM_PROVIDER_NAME 非空时，会注册到 Hermes custom_providers
# 并自动把 model.default 指向该 provider 的 model。
# HERMES_CUSTOM_PROVIDER_API_KEY 留空则使用上面 TOKENFLOW_API_KEY 的值。
HERMES_CUSTOM_PROVIDER_NAME=tokenflow
HERMES_CUSTOM_PROVIDER_BASE_URL=http://36.137.106.15:3030/v1
HERMES_CUSTOM_PROVIDER_API_KEY=
HERMES_CUSTOM_PROVIDER_MODEL=qwen36

# ── Hermes 传统模型配置 (当 HERMES_CUSTOM_PROVIDER_NAME 为空时生效) ──
# HERMES_MODEL=
# HERMES_PROVIDER=openai
# HERMES_BASE_URL=http://36.137.106.15:3030/v1

# ────────────────────────────────────────────
# Hermes Gateway (v1.0.20+ 适配器走 Gateway HTTP API，必填)
# 适配器通过 Gateway API 与 hermes 通信，key 必须与 Gateway 的 API_SERVER_KEY 一致。
# entrypoint 会把本值写入 ~/.hermes/.env 的 API_SERVER_KEY；
# 适配器运行时也读取本值作为请求鉴权。两边不一致会 401。
# 留空则 entrypoint 生成随机值但适配器拿不到 → 调用失败。请生成并固定一个值:
#   openssl rand -hex 16
HERMES_GATEWAY_KEY=

# ────────────────────────────────────────────
# 切换到其他 provider 时，取消下面注释并修改
# 同时把 HERMES_CUSTOM_PROVIDER_NAME 置空
# ────────────────────────────────────────────
# DeepSeek:
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# HERMES_MODEL=deepseek-v4-flash
# HERMES_PROVIDER=deepseek
# HERMES_BASE_URL=https://api.deepseek.com

# OpenAI:
# OPENAI_API_KEY=sk-your-openai-key
# HERMES_MODEL=gpt-4o
# HERMES_PROVIDER=openai
# HERMES_BASE_URL=

# OpenRouter (一个 key 访问 100+ 模型):
# OPENROUTER_API_KEY=sk-or-your-key
# HERMES_MODEL=anthropic/claude-sonnet-4
# HERMES_PROVIDER=openrouter
# HERMES_BASE_URL=

# Gemini:
# GOOGLE_API_KEY=your-google-key
# HERMES_MODEL=gemini-2.5-flash
# HERMES_PROVIDER=google
# HERMES_BASE_URL=

# NovitaAI:
# NOVITA_API_KEY=your-novita-key
# NOVITA_BASE_URL=https://api.novita.ai/openai/v1
# HERMES_MODEL=
# HERMES_PROVIDER=novita
# HERMES_BASE_URL=
